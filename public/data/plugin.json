{
  "plugin": {
    "namespace": "richjava-blog",
    "version": "1.0.0",
    "apiVersion": "1.2",
    "displayName": "Blog",
    "description": "Blog plugin with basic Tailwind styling.",
    "imageUrl": "",
    "language": "typescript",
    "repoName": "richjava/builtjs-plugin-blog",
    "gitProvider": "github",
    "repoUrl": "",
    "demoUrl": "",
    "mainModule": {
      "slug": "blog"
    },
    "requirements": [
      {
        "slug": "tailwind"
      }
    ],
    "config": {
      "frontend": {
        "project": {
          "main": {
            "name": "nextjs",
            "config": {
              "router": "pages"
            }
          },
          "css": {
            "name": "tailwind"
          }
        },
        "node": {
          "dependencies": [
            "date-fns",
            "react-markdown"
          ]
        }
      },
      "backend": {
        "project": {
          "main": {
            "name": "strapi"
          }
        }
      }
    }
  }
}
